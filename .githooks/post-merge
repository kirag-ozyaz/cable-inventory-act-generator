#!/bin/bash

HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=_common.sh
source "$HOOK_DIR/_common.sh"

if [ ! -f "data.7z" ]; then
    exit 0
fi

echo "[+] Расшифровываю data.7z в Data/ и templates/.people.xlsx..."

PASSWORD=$(read_password) || {
    echo "[!] Файл .secret не найден. Распаковка пропущена."
    exit 0
}

SEVEN_ZIP=$(resolve_7z) || {
    echo "[!] 7-Zip не найден."
    exit 1
}

rm -rf Data
rm -f "$PEOPLE_FILE"

unpack_encrypted_archive "$SEVEN_ZIP" "$PASSWORD"

if [ $? -eq 0 ]; then
    echo "[V] Файлы расшифрованы в Data/ и templates/"
else
    echo "[!] Ошибка расшифровки. Неверный пароль?"
fi
