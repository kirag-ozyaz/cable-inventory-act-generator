#!/bin/bash

HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=_common.sh
source "$HOOK_DIR/_common.sh"

if [ ! -d "Data" ] || [ -z "$(ls -A Data 2>/dev/null)" ]; then
    exit 0
fi

echo "[+] ������ ����� �� Data/ � data.7z..."

PASSWORD=$(read_password) || {
    echo "[!] ���� .secret �� ������!"
    exit 1
}

SEVEN_ZIP=$(resolve_7z) || {
    echo "[!] 7-Zip �� ������. ���������� 7-Zip ��� ������� SEVEN_ZIP."
    exit 1
}

rm -f data.7z
"$SEVEN_ZIP" a -t7z -mhe=on -p"$PASSWORD" data.7z ./Data/ > /dev/null 2>&1

if [ $? -ne 0 ]; then
    echo "[!] ������ ����������! ������� ������ � .secret."
    exit 1
fi

git add data.7z
git restore --staged Data/ > /dev/null 2>&1 || git reset HEAD -- Data/ > /dev/null 2>&1

echo "[V] ������! � ������ �������� data.7z"
