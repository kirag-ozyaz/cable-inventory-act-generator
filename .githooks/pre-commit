#!/bin/bash

HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=_common.sh
source "$HOOK_DIR/_common.sh"

if ! has_archive_sources; then
    exit 0
fi

echo "[+] Создаю архив из Data/ и templates/.people.xlsx в data.7z..."

PASSWORD=$(read_password) || {
    echo "[!] Файл .secret не найден!"
    exit 1
}

SEVEN_ZIP=$(resolve_7z) || {
    echo "[!] 7-Zip не найден. Установите 7-Zip или задайте SEVEN_ZIP."
    exit 1
}

pack_encrypted_archive "$SEVEN_ZIP" "$PASSWORD"

if [ $? -ne 0 ]; then
    echo "[!] Ошибка архивации 7-Zip. Возможные причины: файл data.7z занят другим процессом или неверный пароль в .secret."
    exit 1
fi

git add data.7z
unstage_local_secrets

echo "[V] Готово! В коммит добавлен data.7z"
